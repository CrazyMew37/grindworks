attack_lines = Array[String](["I'm cutting you from Toontown.", "Sorry, but you don't make the cut.", "I have a sharp opinion of you.", "Chop-chop, get out of here!", "Here's a slice of my power.", "You'll be slashed out of here.", "I'll have to make a snip from you.", "I have some real cutthroat tactics.", "Good knife, Toon.", "I'm staring daggers at you."])
