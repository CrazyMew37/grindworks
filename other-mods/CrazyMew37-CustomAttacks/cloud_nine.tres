[gd_resource type="Resource" load_steps=2 format=3 uid="uid://cl1wjmid0xkna"]

[sub_resource type="GDScript" id="GDScript_iatwp"]
script/source = "extends CogAttack

const SFX_GRUNT := preload(\"res://audio/sfx/toon/target_impact_grunt1.ogg\")
const SFX_IMPACT := preload(\"res://audio/sfx/misc/target_impact_only.ogg\")

const MOLE_HOLE := preload('res://models/props/cog_props/cloud/cloud.tscn')


func action() -> void:
	var player : Player = targets[0]
	
	# Create the mole hill for the attack
	var mole_hill := MOLE_HOLE.instantiate()
	battle_node.add_child(mole_hill)
	mole_hill.hide()
	mole_hill.global_position = player.global_position
	mole_hill.rotation_degrees.y += 180.0
	mole_hill.scale *= 0.1
	
	# Accuracy check
	var hit := manager.roll_for_accuracy(self)
	
	# Movie Start
	var movie := manager.create_tween()
	
	# Focus Cog
	movie.tween_callback(battle_node.focus_character.bind(user, 6.0))
	movie.tween_callback(user.set_animation.bind('magic1'))
	movie.tween_interval(1.0)
	
	# Mole Pops up
	movie.tween_callback(mole_hill.show)
	movie.tween_callback(battle_node.focus_character.bind(player))
	
	if hit:
	
		# Toon flies away into the stratosphere
		movie.tween_callback(player.set_animation.bind('melt-nosink'))
		movie.set_trans(Tween.TRANS_QUAD)
		movie.tween_property(mole_hill,'scale', Vector3(1.0,1.0,1.0), 0.1)
		movie.set_trans(Tween.TRANS_LINEAR)
		movie.tween_property(mole_hill, 'position:y', 1.5, 2.3)
		movie.parallel().tween_property(player.toon, 'position:y', 1.5, 2.3)
		movie.set_trans(Tween.TRANS_QUAD)
		movie.tween_property(mole_hill,'scale', Vector3(0.01,0.01,0.01), 0.25)
		movie.parallel().tween_callback(player.set_animation.bind('slip-forward'))
		movie.set_trans(Tween.TRANS_LINEAR)
		movie.parallel().tween_property(player.toon, 'position:y', 0, 0.4)
		movie.tween_callback(manager.affect_target.bind(player, damage))
		movie.tween_callback(AudioManager.play_sound.bind(SFX_GRUNT))
		movie.tween_callback(AudioManager.play_sound.bind(SFX_IMPACT))
	else:
		movie.parallel().tween_callback(player.set_animation.bind('sidestep-left'))
		movie.set_trans(Tween.TRANS_QUAD)
		movie.tween_property(mole_hill,'scale', Vector3(1.0,1.0,1.0), 0.1)
		movie.set_trans(Tween.TRANS_LINEAR)
		movie.tween_property(mole_hill, 'position:y', 1.5, 2.3)
		movie.tween_callback(manager.battle_text.bind(player, \"MISSED\"))
		movie.set_trans(Tween.TRANS_QUAD)
		movie.tween_property(mole_hill,'scale', Vector3(0.01,0.01,0.01), 0.25)
	
	movie.tween_interval(3.0)
	
	await movie.finished
	movie.kill()
	
	await manager.check_pulses(targets)
	mole_hill.queue_free()
"

[resource]
script = SubResource("GDScript_iatwp")
damage = 4
attack_lines = Array[String](["I believe you can fly!", "It's time for you to soar into the heavens.", "Your thoughts are clouded.", "I can think of nine ways that this can go badly.", "You're such an airhead.", "Get your head out of the clouds!", "Ever wished you could fly?", "Don't get too close to the sun now.", "Today's weather will be partially cloudy.", "Float somewhere else, Toon."])
action_name = "Cloud Nine"
