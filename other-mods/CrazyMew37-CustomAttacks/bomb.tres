custom_method = "bomb"
damage = 6
attack_lines = Array[String](["I'm the bomb!", "Defuse this situation.", "I'm about to blow!", "This is going to blow up in your face.", "You're a real dud.", "C4 you later.", "You'll go out in a big explosion.", "What? I thought explosions were fun.", "You've lit my fuse!", "Time for an action scene."])
