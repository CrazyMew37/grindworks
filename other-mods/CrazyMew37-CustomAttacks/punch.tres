[gd_resource type="Resource" load_steps=2 format=3 uid="uid://cbq52i0hlvgcs"]

[sub_resource type="GDScript" id="GDScript_0bmmd"]
script/source = "extends CogAttack


func action():
	# Setup
	var hit := manager.roll_for_accuracy(self)
	var target : Player = targets[0]
	user.face_position(target.global_position)
	var tween := manager.create_tween()
	manager.s_focus_char.emit(user)
	tween.tween_callback(user.set_animation.bind('glower'))
	tween.tween_callback(user.animator.set_speed_scale.bind(3.0))
	
	await manager.sleep(0.4)
	manager.s_focus_char.emit(target)
	
	# Base toon anim on whether target was hit
	if hit:
		target.set_animation('slip-backward')
		AudioManager.play_sound(load('res://audio/sfx/battle/gags/drop/AA_drop_sandbag.ogg'))
	else:
		target.set_animation('jump-back-right')
	
	# Affect target, or don't
	if hit:
		manager.affect_target(target, damage)
	else:
		manager.battle_text(target,\"MISSED\")

	tween.kill()
	
	await manager.barrier(target.animator.animation_finished, 5.0)
	user.animator.set_speed_scale(1.0)
	
	await manager.check_pulses(targets)
"

[resource]
script = SubResource("GDScript_0bmmd")
damage = 4
attack_lines = Array[String](["I'll rock you till I sock you.", "I'm gonna punch your face!", "Enjoy eating my knuckle sandwich.", "Prepare for a fist... full of pain!", "I'll make you my punching bag.", "Grrr... I've had enough of you!", "You look easily punchable.", "Consider this to be my greatest hit.", "No more playing around. It's time for a REAL attack.", "I have a fist made of iron, and the other is steel."])
action_name = "Punch"
