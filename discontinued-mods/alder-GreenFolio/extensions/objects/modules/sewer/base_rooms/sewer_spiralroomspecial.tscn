[sub_resource type="GDScript" id="GDScript_vuy0y"]
resource_name = "specialchestplaform"
script/source = "extends Node3D
const LOWER_DISTANCE := 3.0
const LOWER_DURATION := 1.5
const SFX_LOWER := preload(\"res://audio/sfx/misc/MG_sfx_travel_game_bonus.ogg\")
@onready var camera : Camera3D = $SceneCamera
@onready var platform : Node3D = $Platform
@onready var sfx_fall : AudioStreamPlayer3D = $SFXFall
@onready var sfx_land : AudioStreamPlayer3D = $SFXLand

func lower_platform() -> void:
	if is_instance_valid(Util.get_player()):
		Util.get_player().state = Player.PlayerState.STOPPED
		Util.get_player().set_animation('neutral')
	
	var tween := create_tween()
	tween.tween_callback(camera.make_current)
	tween.tween_interval(0.5)
	tween.tween_callback(sfx_fall.play)
	tween.tween_callback(
		func():
			await Task.delay(LOWER_DURATION - 0.15)
			sfx_fall.stop()
			#sfx_land.play()
			await Task.delay(1.0)
			sfx_land.volume_db = -10.0
			sfx_land.play()
			#await Task.delay(0.4)
			sfx_land.volume_db = -20.0
			#sfx_land.play()
	)
	
	tween.set_ease(Tween.EASE_IN_OUT)
	tween.set_trans(Tween.TRANS_CUBIC)
	tween.tween_property(platform, 'position:y', platform.position.y - LOWER_DISTANCE, LOWER_DURATION)
	tween.tween_interval(0.5)
	tween.tween_callback(AudioManager.play_sound.bind(SFX_LOWER))
	
	await tween.finished
	tween.kill()
	
	if is_instance_valid(Util.get_player()):
		Util.get_player().camera.make_current()
		Util.get_player().state = Player.PlayerState.WALK

func _cog_button_pressed(button: CogButton) -> void:
	lower_platform()
"

